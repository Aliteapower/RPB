# RPB protected public acceptance backend environment.
# Copy to /etc/rpb/rpb-backend.env and replace all placeholder values.
# Do not use real business data or production credentials in this environment.

SERVER_PORT=8080

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rpb_acceptance
DB_USERNAME=rpb_acceptance_app
DB_PASSWORD=replace-with-acceptance-only-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

JWT_SECRET=replace-with-acceptance-only-secret

SPRING_FLYWAY_ENABLED=true
RPB_LOCAL_AUTH_ENABLED=false
RPB_CALL_SCREEN_MEDIA_STORAGE_ROOT=/opt/rpb/media

